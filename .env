# Database Configuration
DATABASE_URL=postgresql://workforce:securepassword@localhost:5432/workforce_intelligence
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Server Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# Multi-tenancy
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=24h
BCRYPT_ROUNDS=10

# LLM Configuration (Abstraction Layer)
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Vector Store Configuration
VECTOR_STORE_PROVIDER=pinecone
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=workforce-intelligence
PINECONE_ENVIRONMENT=production

# RAG Configuration
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
RAG_TOP_K_RESULTS=5
RAG_CONFIDENCE_THRESHOLD=0.7

# Skill Scoring Configuration
SKILL_SCORING_VERSION=1.0
PROMOTION_READINESS_WEIGHTS={"technical":0.4,"leadership":0.3,"communication":0.2,"strategic":0.1}

# Document Processing
MAX_FILE_SIZE=52428800
SUPPORTED_FILE_TYPES=pdf,docx,md

# Compliance & Audit
ENABLE_AUDIT_LOGGING=true
AUDIT_LOG_RETENTION_DAYS=365

# Feature Flags
ENABLE_INCIDENT_SIMULATIONS=true
ENABLE_ANALYTICS_CACHE=true
ANALYTICS_CACHE_TTL_SECONDS=3600
