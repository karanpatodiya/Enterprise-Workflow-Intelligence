{
  "name": "enterprise-workforce-intelligence",
  "version": "1.0.0",
  "description": "Production-grade B2B SaaS backend for Enterprise Workforce Intelligence & Skill Optimization",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node src/app.ts",
    "build": "tsc",
    "build:frontend": "npm --prefix frontend run build",
    "build:all": "npm run build && npm run build:frontend",
    "start": "node dist/app.js",
    "start:single-port": "npm run build:all && node dist/app.js",
    "setup:local": "npm run migrate && npm run fix:db-perms && npm run generate:token",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "migrate": "ts-node scripts/migrate.ts",
    "seed": "ts-node scripts/seed.ts",
    "fix:db-perms": "ts-node scripts/fix-db-permissions.ts",
    "generate:token": "ts-node scripts/generate-token.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.6.5",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.6",
    "docx": "^8.5.0",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.3",
    "markdown-it": "^14.0.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.11.3",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.11.2",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vite": "^7.3.1"
  }
}
